{
  "name": "portfolio-monorepo",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter portfolio --filter admin run dev",
    "dev:portfolio": "pnpm --filter portfolio run dev",
    "dev:admin": "pnpm --filter admin run dev",
    "build": "pnpm --filter portfolio run build && pnpm --filter admin run build",
    "build:portfolio": "pnpm --filter portfolio run build",
    "build:admin": "pnpm --filter admin run build",
    "test": "pnpm --filter portfolio run test && pnpm --filter admin run test",
    "db:migrate": "pnpm --filter admin run typeorm:migrate",
    "db:seed": "pnpm --filter admin run typeorm:seed",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:logs:admin": "docker compose logs -f admin",
    "docker:logs:portfolio": "docker compose logs -f portfolio",
    "docker:restart": "docker compose restart",
    "docker:ps": "docker compose ps",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:sync-schema": "docker compose exec -T admin tsx scripts/sync-schema.ts",
    "docker:seed": "docker compose exec -T postgres psql -U ${POSTGRES_USER:-portfolio_user} -d ${POSTGRES_DB:-portfolio_db} < docker/postgres/seed.sql"
  }
}
