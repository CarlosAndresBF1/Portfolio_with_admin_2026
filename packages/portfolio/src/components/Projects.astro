---
import type { Lang } from "../i18n";
import { useTranslations } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const projects: { title: string; description: string; stack: string[] }[] =
  t.projects ?? [];
const sectionTitle = lang === "es" ? "Proyectos" : "Projects";
---

<section class="projects flex-col-wise full-vh" id="projects">
  <div class="container flex-col-wise">
    <div class="projectContainer row g-3">
      <div class="col-lg-12 col-12">
        <span class="titleFont mx-2">{sectionTitle}</span>
      </div>
      {
        projects.map((project, idx) => (
          <div
            class={`projectItem ${idx === 0 ? "col-lg-8 col-12" : "col-lg-4 col-6"}`}
          >
            <div class="card">
              <div class="card-body d-flex flex-column justify-content-end p-4">
                <h3 class="normalFont" style="font-size:20px;">
                  {project.title}
                </h3>
                <p
                  class="normalFont"
                  style="font-size:14px; color: var(--text-theme-secondary);"
                >
                  {project.description}
                </p>
                <div class="d-flex flex-wrap gap-1">
                  {project.stack.map((tech) => (
                    <span class="bubbleData normalFont">{tech}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    background-color: var(--bg-theme-primary);
  }
  .projectContainer {
    width: 100%;
  }
  .projectItem {
    min-height: 200px;
  }
  .card {
    background-color: var(--bg-theme-secondary);
    height: 100%;
    border-radius: 10px;
    margin-top: 10px;
    border: 1px solid #ffffff0d;
    transition: border-color 0.3s ease;
  }
  .card:hover {
    border-color: #ffffff2a;
  }
  .bubbleData {
    display: inline-block;
    padding: 2px 10px;
    border: 1px solid #949494;
    border-radius: 5px;
    font-size: 12px !important;
  }
  @media only screen and (max-width: 600px) {
    .projects {
      padding: 50px 0px;
    }
  }
</style>
