# ── Google Analytics 4 (público, accesible en el browser) ─────────────────────
# Usa PUBLIC_GA_ID para GA4 (IDs que empiezan con G-)
PUBLIC_GA_ID=

# ── Google Tag Manager (alternativa a GA4) ────────────────────────────────────
# Usa PUBLIC_GTM_ID para GTM (IDs que empiezan con GTM-)
PUBLIC_GTM_ID=

# ── Admin API (server-side only) ───────────────────────────────────────────────
# En Docker: http://admin:3000  |  En local: http://localhost:3000
ADMIN_API_URL=http://localhost:3000
INTERNAL_API_KEY=replace_with_openssl_rand_-hex_32

# ── Email (formulario de contacto) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
CONTACT_TO_EMAIL=your_email@gmail.com
CONTACT_FROM_EMAIL=

# ── Puerto ────────────────────────────────────────────────────────────────────
PORT=4321
HOST=0.0.0.0
