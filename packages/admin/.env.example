# ── Base de datos ──────────────────────────────────────────────────────────────
# Para desarrollo local (postgres en localhost):
DATABASE_URL=postgresql://portfolio_user:portfolio_pass@localhost:5432/portfolio_db
# Para Docker (postgres en el mismo compose):
# DATABASE_URL=postgresql://portfolio_user:portfolio_pass@postgres:5432/portfolio_db

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=replace_with_openssl_rand_-hex_32
NEXTAUTH_URL=http://localhost:3000

# ── Admin user inicial (para seed) ────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ── Comunicación interna con el portfolio ─────────────────────────────────────
INTERNAL_API_KEY=replace_with_openssl_rand_-hex_32
PORTFOLIO_URL=http://localhost:4321

# ── Puertos ──────────────────────────────────────────────────────────────────
PORT=3000
PORTFOLIO_PORT=4321
