# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_DB=portfolio_db
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# URL usada por Prisma (apunta al contenedor Docker en producción)
DATABASE_URL=postgresql://portfolio_user:change_me_in_production@postgres:5432/portfolio_db
# Para desarrollo local (sin Docker): usar localhost
# DATABASE_URL=postgresql://portfolio_user:change_me_in_production@localhost:5432/portfolio_db

# ============================================================
# ADMIN PANEL (Next.js)
# ============================================================
ADMIN_PORT=3000
ADMIN_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Generar con: openssl rand -hex 32
NEXTAUTH_SECRET=replace_with_openssl_rand_-hex_32

# Usuario admin inicial (usado en el seed de Prisma)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ============================================================
# PORTFOLIO (Astro)
# ============================================================
PORTFOLIO_PORT=4321
PORTFOLIO_BASE_URL=http://localhost:4321
# Google Tag Manager (opcional)
PUBLIC_GTM_ID=

# ============================================================
# COMUNICACIÓN INTERNA (admin <-> portfolio)
# ============================================================
# URL que usa el portfolio para llamar al admin (interna en Docker)
ADMIN_API_URL=http://admin:3000
# Para desarrollo local:
# ADMIN_API_URL=http://localhost:3000

# API Key compartida (autenticación interna entre servicios)
# Generar con: openssl rand -hex 32
INTERNAL_API_KEY=replace_with_openssl_rand_-hex_32

# URL del portfolio para CORS en el admin
PORTFOLIO_URL=http://localhost:4321

# ============================================================
# EMAIL (usado por el portfolio para el formulario de contacto)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
CONTACT_TO_EMAIL=your_email@gmail.com
CONTACT_FROM_EMAIL=
